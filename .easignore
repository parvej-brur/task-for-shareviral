# Exclude development and version control files
node_modules/
.git/
.github/
.vscode/
.idea/

# Exclude build artifacts
dist/
web-build/
build/

# Exclude test files
__tests__/
*.test.js
*.test.ts
*.test.tsx
jest.config.js
jest.setup.js

# Exclude documentation
docs/
*.md
LICENSE

# Exclude macOS system files
.DS_Store


# Exclude logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Exclude temporary files
tmp/
temp/

# Exclude large assets not needed for builds
assets/raw/

# Exclude local dev bundle ID (matches .gitignore)
ios/
android/
